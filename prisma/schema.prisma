generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Domain Enums (SQLite: stored as String) ───

// ProjectStatus = draft | generating | generated | failed | exported
// AssetSourceType = uploaded | generated | byoi_edited
// JobStatus = queued | running | done | failed

// ─── User / Workspace / Membership ───

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  memberships Membership[]
  projects    Project[]
  composeTemplates ComposeTemplate[]
  usageLedger UsageLedger[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("owner")
  plan        String   @default("solo_free")
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
}

// ─── Project ───

model Project {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  status      String          @default("draft")
  briefText   String?
  mode        String?
  editorMode  String?         @default("flow")
  templateKey String?
  content     String?
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  assets      Asset[]
  jobs        GenerationJob[]
  exports     ExportArtifact[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// ─── Asset ───

model Asset {
  id              String   @id @default(cuid())
  projectId       String
  sourceType      String   @default("uploaded")
  filePath        String
  mimeType        String?
  preserveOriginal Boolean @default(false)
  project         Project  @relation(fields: [projectId], references: [id])
  createdAt       DateTime @default(now())
}

// ─── GenerationJob ───

model GenerationJob {
  id        String   @id @default(cuid())
  projectId String
  status    String   @default("queued")
  provider  String?
  input     String?
  output    String?
  error     String?
  project   Project  @relation(fields: [projectId], references: [id])
  startedAt DateTime?
  doneAt    DateTime?
  createdAt DateTime @default(now())
}

// ─── ExportArtifact ───

model ExportArtifact {
  id        String   @id @default(cuid())
  projectId String
  type      String
  filePath  String
  metadata  String?
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

// ─── UsageLedger ───

model UsageLedger {
  id          String   @id @default(cuid())
  workspaceId String
  eventType   String
  detail      String?
  costEstimate Float?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
}

model ComposeTemplate {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  snapshot       String
  previewTitle   String?
  blockCount     Int       @default(0)
  sourceProjectId String?
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── PlanCatalog ───

model PlanCatalog {
  id              String @id @default(cuid())
  tier            String @unique
  monthlyLimit    Int    @default(0)
  features        String?
  createdAt       DateTime @default(now())
}
