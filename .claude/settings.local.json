{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(netstat:*)",
      "Bash(npm install:*)",
      "WebFetch(domain:www.elancer.co.kr)",
      "Bash(rm:*)",
      "WebFetch(domain:blog.naver.com)",
      "WebFetch(domain:cafe.naver.com)",
      "mcp__notebooklm__ask_question",
      "mcp__notebooklm__list_notebooks"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
