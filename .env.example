DATABASE_URL="file:./dev.db"
OLLAMA_BASE_URL="http://localhost:11434"
DEFAULT_WORKSPACE_NAME="default"
GEMINI_API_KEY="your-gemini-api-key"
KIE_API_KEY="your-kie-ai-api-key"
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"
UPLOADS_DIR="./uploads"
UPLOADS_BACKUP_DIR=""

# Image generation provider: "kie" (default, API) | "comfyui" (local)
IMAGE_PROVIDER="kie"

# ComfyUI settings (only needed when IMAGE_PROVIDER="comfyui")
COMFYUI_URL="http://localhost:8188"
COMFYUI_MODEL="flux1-dev-fp8.safetensors"

# Deployment mode: "self-hosted" (Mac Mini) | "saas" (cloud)
DEPLOYMENT_MODE="self-hosted"
